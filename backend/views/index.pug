doctype html
head(lang='fr')
  meta(charset='utf-8')
  title Codecast
body(id='app')
  div(id='react-container')
    div(style='width: 256px; height: 256px; margin: 0 auto;')
      img(src=rebaseUrl('assets/loading.gif'))
  if development
    script(type='module', src=rebaseUrl('@vite/client'))
    script(type='module').
      import RefreshRuntime from "!{rebaseUrl('@react-refresh')}"
      RefreshRuntime.injectIntoGlobalHook(window)
      window.$RefreshReg$ = () => {}
      window.$RefreshSig$ = () => () => {}
      window.__vite_plugin_react_preamble_installed__ = true
    script(type='module', src=rebaseUrl('frontend/index.tsx'))
  else
    script(type='text/javascript', src=rebaseUrl('build/index.js'))
  script(type='text/javascript').
    window.addEventListener('load', () => {
      Codecast.start(!{JSON.stringify(options)})
    })
