  "scripts": {
    "dev": "nodemon --mode development --watch backend --exec yarn babel-node -- backend/server.js",
    "start": "NODE_ENV=production nodemon --mode production --watch backend --exec yarn babel-node -- backend/server.js",
    "build": "vite build --mode production",
    "build-lib": "BUILD=lib vite build --mode production",
    "watch-lib": "BUILD=lib vite build --mode production --watch",
    "pack-offline": "rm -rf build && yarn run build-lib && zip -r offline.zip build assets",
    "lint": "./node_modules/.bin/eslint frontend/ --ext .tsx,.ts"
  },
